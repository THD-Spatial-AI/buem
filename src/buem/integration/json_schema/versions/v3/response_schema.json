{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://buem.energy/schemas/v3/response",
  "title": "BUEM GeoJSON Response Schema v3",
  "description": "Response schema for the BUEM building energy model. Echoes the full v3 request structure and adds thermal_load_profile and model_metadata to each feature's buem node. All output quantities carry explicit unit fields. Timeseries arrays declare their unit once at the array level.",
  "type": "object",
  "required": ["type", "features"],
  "properties": {
    "type": {
      "const": "FeatureCollection",
      "description": "GeoJSON type identifier"
    },
    "timeStamp": {
      "type": "string",
      "format": "date-time",
      "description": "Response timestamp"
    },
    "processed_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when processing completed"
    },
    "processing_elapsed_s": {
      "type": "number",
      "description": "Total wall-clock time for the full request in seconds"
    },
    "metadata": { "$ref": "#/$defs/collection_metadata" },
    "features": {
      "type": "array",
      "items": { "$ref": "#/$defs/feature" },
      "description": "Array of processed building features with results appended"
    }
  },

  "$defs": {

    "collection_metadata": {
      "type": "object",
      "description": "Aggregate processing statistics for the feature collection",
      "required": ["total_features", "successful_features", "failed_features"],
      "properties": {
        "total_features": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of features received"
        },
        "successful_features": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of features successfully processed"
        },
        "failed_features": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of features that failed processing"
        },
        "validation_warnings": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of validation warnings across all features"
        }
      }
    },

    "feature": {
      "type": "object",
      "required": ["type", "id", "geometry", "properties"],
      "properties": {
        "type": { "const": "Feature" },
        "id": {
          "type": "string",
          "description": "Building identifier — echoed from request"
        },
        "geometry": { "$ref": "#/$defs/geometry" },
        "properties": { "$ref": "#/$defs/properties" }
      }
    },

    "geometry": {
      "type": "object",
      "required": ["type", "coordinates"],
      "properties": {
        "type": { "const": "Point" },
        "coordinates": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 2,
          "maxItems": 3,
          "description": "Geographic coordinates [longitude, latitude, elevation?] — echoed from request"
        }
      }
    },

    "properties": {
      "type": "object",
      "required": ["start_time", "end_time", "resolution", "resolution_unit", "buem"],
      "properties": {
        "start_time": {
          "type": "string",
          "format": "date-time",
          "description": "Simulation start time — echoed from request"
        },
        "end_time": {
          "type": "string",
          "format": "date-time",
          "description": "Simulation end time — echoed from request"
        },
        "resolution": {
          "type": "string",
          "description": "Time resolution value — echoed from request"
        },
        "resolution_unit": {
          "type": "string",
          "description": "Time resolution unit — echoed from request"
        },
        "buem": { "$ref": "#/$defs/buem" }
      }
    },

    "buem": {
      "type": "object",
      "required": ["building", "thermal_load_profile"],
      "description": "Echoes the request buem node (building contains envelope and thermal) and appends thermal_load_profile and model_metadata",
      "properties": {
        "building":             { "type": "object", "description": "Echoed from request — contains envelope and thermal as nested objects" },
        "solver":               { "type": "object", "description": "Echoed from request" },
        "thermal_load_profile": { "$ref": "#/$defs/thermal_load_profile" },
        "model_metadata":       { "$ref": "#/$defs/model_metadata" }
      }
    },

    "thermal_load_profile": {
      "type": "object",
      "required": ["start_time", "end_time", "resolution", "resolution_unit", "summary"],
      "description": "Computed thermal load results for the building",
      "properties": {
        "start_time": {
          "type": "string",
          "format": "date-time",
          "description": "First timestamp in the simulation output"
        },
        "end_time": {
          "type": "string",
          "format": "date-time",
          "description": "Last timestamp in the simulation output"
        },
        "resolution": {
          "type": "string",
          "description": "Time resolution of the output"
        },
        "resolution_unit": {
          "type": "string",
          "description": "Unit of the time resolution"
        },
        "summary":        { "$ref": "#/$defs/load_summary" },
        "timeseries":     { "$ref": "#/$defs/load_timeseries" },
        "timeseries_file": {
          "type": "string",
          "description": "Download path for the full gzip timeseries file — present when the file was saved server-side"
        }
      }
    },

    "load_summary": {
      "type": "object",
      "required": ["heating", "cooling", "electricity"],
      "description": "Aggregated statistics over the full simulation period",
      "properties": {
        "heating":     { "$ref": "#/$defs/energy_summary" },
        "cooling":     { "$ref": "#/$defs/energy_summary" },
        "electricity": { "$ref": "#/$defs/energy_summary" },
        "total_energy_demand": {
          "allOf": [{ "$ref": "#/$defs/energy_qty" }],
          "description": "Total heating + cooling + electricity demand over the simulation period"
        },
        "peak_heating_load": {
          "allOf": [{ "$ref": "#/$defs/power_qty" }],
          "description": "Maximum instantaneous heating load"
        },
        "peak_cooling_load": {
          "allOf": [{ "$ref": "#/$defs/power_qty" }],
          "description": "Maximum instantaneous cooling load"
        },
        "energy_intensity": {
          "allOf": [{ "$ref": "#/$defs/energy_intensity_qty" }],
          "description": "Total energy demand per reference floor area"
        }
      }
    },

    "energy_summary": {
      "type": "object",
      "required": ["total", "max", "min", "mean"],
      "description": "Statistical summary for one energy carrier over the simulation period",
      "properties": {
        "total": {
          "allOf": [{ "$ref": "#/$defs/energy_qty" }],
          "description": "Total energy over the simulation period"
        },
        "max": {
          "allOf": [{ "$ref": "#/$defs/power_qty" }],
          "description": "Peak instantaneous power"
        },
        "min": {
          "allOf": [{ "$ref": "#/$defs/power_qty" }],
          "description": "Minimum instantaneous power"
        },
        "mean": {
          "allOf": [{ "$ref": "#/$defs/power_qty" }],
          "description": "Mean power over the simulation period"
        },
        "median": {
          "allOf": [{ "$ref": "#/$defs/power_qty" }],
          "description": "Median power over the simulation period"
        },
        "std": {
          "allOf": [{ "$ref": "#/$defs/power_qty" }],
          "description": "Standard deviation of power over the simulation period"
        }
      }
    },

    "load_timeseries": {
      "type": "object",
      "required": ["unit", "timestamps", "heating", "cooling", "electricity"],
      "description": "Hourly timeseries arrays — only present when ?include_timeseries=true is passed to the endpoint. Unit applies to all three load arrays.",
      "properties": {
        "unit": {
          "type": "string",
          "enum": ["kW", "W", "MW"],
          "default": "kW",
          "description": "Unit for all load arrays (heating, cooling, electricity)"
        },
        "timestamps": {
          "type": "array",
          "items": { "type": "string", "format": "date-time" },
          "description": "ISO 8601 timestamps, one per time step"
        },
        "heating": {
          "type": "array",
          "items": { "type": "number" },
          "description": "Heating load at each time step"
        },
        "cooling": {
          "type": "array",
          "items": { "type": "number" },
          "description": "Cooling load at each time step"
        },
        "electricity": {
          "type": "array",
          "items": { "type": "number" },
          "description": "Electricity consumption at each time step"
        }
      }
    },

    "model_metadata": {
      "type": "object",
      "description": "Diagnostic information about the model run",
      "properties": {
        "model_version": {
          "type": "string",
          "description": "BUEM model version used"
        },
        "solver_used": {
          "type": "string",
          "description": "Solver selected for the run (e.g. scipy-sparse, OSQP, CBC)"
        },
        "processing_time": {
          "allOf": [{ "$ref": "#/$defs/duration_qty" }],
          "description": "Wall-clock time for this feature"
        },
        "weather_year": {
          "type": "integer",
          "description": "Calendar year of the weather data used"
        },
        "parallel_thermal": {
          "type": "boolean",
          "description": "Whether heating and cooling were run in parallel"
        },
        "use_chunked_processing": {
          "type": "boolean",
          "description": "Whether chunked processing was used"
        },
        "validation_warnings": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Any validation warnings generated during processing"
        }
      }
    },

    "measurement": {
      "type": "object",
      "required": ["value"],
      "description": "Base type for all measurable quantities. Unit defaults to SI when omitted.",
      "properties": {
        "value": { "type": "number" },
        "unit":  { "type": "string" }
      }
    },

    "energy_qty": {
      "allOf": [{ "$ref": "#/$defs/measurement" }],
      "properties": {
        "value": { "minimum": 0 },
        "unit":  { "enum": ["kWh", "MWh", "Wh"], "default": "kWh" }
      }
    },

    "power_qty": {
      "allOf": [{ "$ref": "#/$defs/measurement" }],
      "properties": {
        "unit": { "enum": ["kW", "W", "MW"], "default": "kW" }
      }
    },

    "energy_intensity_qty": {
      "allOf": [{ "$ref": "#/$defs/measurement" }],
      "properties": {
        "value": { "minimum": 0 },
        "unit":  { "enum": ["kWh/m2", "kWh/ft2"], "default": "kWh/m2" }
      }
    },

    "duration_qty": {
      "allOf": [{ "$ref": "#/$defs/measurement" }],
      "properties": {
        "value": { "minimum": 0 },
        "unit":  { "enum": ["s", "ms", "min"], "default": "s" }
      }
    }

  }
}
